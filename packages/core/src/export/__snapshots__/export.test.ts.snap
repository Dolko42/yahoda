exports[`golden snapshots > tailwind 1`] = `
"/*
 * Yahoda export — Tailwind theme
 * system: Acme UI
 * schemaVersion: 1.0.0
 * commit: draft
 */
import type { Config } from "tailwindcss";

const config: Pick<Config, "theme"> = {
  "theme": {
    "extend": {
      "colors": {
        "border": "var(--color-border)",
        "danger": "var(--color-danger)",
        "primary": "var(--color-primary)",
        "primaryHover": "var(--color-primaryHover)",
        "surface": "var(--color-surface)",
        "text": "var(--color-text)",
        "textOnPrimary": "var(--color-textOnPrimary)",
        "transparent": "var(--color-transparent)",
        "palette.blue.600": "var(--palette-blue-600)",
        "palette.blue.700": "var(--palette-blue-700)",
        "palette.red.600": "var(--palette-red-600)",
        "palette.slate.300": "var(--palette-slate-300)",
        "palette.slate.900": "var(--palette-slate-900)",
        "palette.white": "var(--palette-white)"
      },
      "borderRadius": {
        "lg": "var(--radius-lg)",
        "md": "var(--radius-md)",
        "sm": "var(--radius-sm)"
      },
      "spacing": {
        "1": "var(--spacing-1)",
