"/*
 * Yahoda export — CSS variables
 * system: Acme UI
 * schemaVersion: 1.0.0
 * commit: draft
 */
:root {
  /* primitives */
  --font-body: "Inter", system-ui, sans-serif;
  --font-heading: "Inter Tight", "Inter", system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, monospace;
  --palette-blue-600: #2448B8;
  --palette-blue-700: #1E3FA0;
  --palette-red-600: #C0341D;
  --palette-slate-300: #C4C9D1;
  --palette-slate-900: #181A1D;
  --palette-white: #FFFFFF;
  --typography-body-base-font-family: var(--font-body);
  --typography-body-base-font-size: 1rem;
  --typography-body-base-line-height: 1.5;
  --typography-body-base-font-weight: 400;
  --typography-heading-base-font-family: var(--font-heading);
  --typography-heading-base-font-size: 1rem;
  --typography-heading-base-line-height: 1.15;
  --typography-heading-base-font-weight: 700;
  --typography-heading-base-letter-spacing: -0.02em;
  --typography-label-base-font-family: var(--font-body);
  --typography-label-base-font-size: 1rem;
  --typography-label-base-line-height: 1.4;
  --typography-label-base-font-weight: 500;
  --typography-link-base-font-family: var(--font-body);
  --typography-link-base-font-size: 1rem;
  --typography-link-base-line-height: 1.5;
  --typography-link-base-font-weight: 500;
  /* semantic */
  --color-border: var(--palette-slate-300);
  --color-danger: var(--palette-red-600);
  --color-primary: var(--palette-blue-600);
  --color-primaryHover: var(--palette-blue-700);
  --color-surface: var(--palette-white);
  --color-text: var(--palette-slate-900);
  --color-textOnPrimary: var(--palette-white);
  --color-transparent: transparent;
  --duration-fast: 150ms;
  --easing-standard: cubic-bezier(0.2, 0, 0, 1);
  --radius-lg: 12px;
  --radius-md: 8px;
  --radius-sm: 4px;
  --shadow-md: 0px 6px 16px -4px rgba(24,26,29,0.16);
  --shadow-sm: 0px 1px 2px 0px rgba(24,26,29,0.08);
