exports[`golden snapshots > tailwind 1`] = `
"/*
 * Yahoda export — Tailwind theme
 * system: Acme UI
 * schemaVersion: 1.0.0
 * commit: draft
 */
import type { Config } from "tailwindcss";

const config: Pick<Config, "theme"> = {
  "theme": {
    "extend": {
      "colors": {
        "border": "var(--color-border)",
        "danger": "var(--color-danger)",
        "primary": "var(--color-primary)",
        "primaryHover": "var(--color-primaryHover)",
        "surface": "var(--color-surface)",
        "text": "var(--color-text)",
        "textOnPrimary": "var(--color-textOnPrimary)",
        "transparent": "var(--color-transparent)",
        "palette.blue.600": "var(--palette-blue-600)",
        "palette.blue.700": "var(--palette-blue-700)",
        "palette.red.600": "var(--palette-red-600)",
        "palette.slate.300": "var(--palette-slate-300)",
        "palette.slate.900": "var(--palette-slate-900)",
        "palette.white": "var(--palette-white)"
      },
      "borderRadius": {
        "lg": "var(--radius-lg)",
        "md": "var(--radius-md)",
        "sm": "var(--radius-sm)"
      },
      "spacing": {
        "1": "var(--spacing-1)",
        "2": "var(--spacing-2)",
        "3": "var(--spacing-3)",
        "4": "var(--spacing-4)",
        "6": "var(--spacing-6)"
      },
      "fontFamily": {
        "mono": "var(--fontFamily-mono)",
        "sans": "var(--fontFamily-sans)"
      },
      "fontSize": {
        "lg": "var(--fontSize-lg)",
        "md": "var(--fontSize-md)",
        "sm": "var(--fontSize-sm)",
        "xl": "var(--fontSize-xl)",
        "body-md": [
          "var(--fontSize-md)",
          {
            "lineHeight": "1.5",
            "fontWeight": "400"
          }
        ],
        "heading-lg": [
          "var(--fontSize-xl)",
          {
            "lineHeight": "1.2",
            "fontWeight": "700"
          }
        ],
        "label-sm": [
          "var(--fontSize-sm)",
          {
            "lineHeight": "1.4",
            "fontWeight": "500"
          }
        ]
      },
      "boxShadow": {
        "md": "var(--shadow-md)",
        "sm": "var(--shadow-sm)"
      },
      "transitionDuration": {
        "fast": "var(--duration-fast)"
      },
      "transitionTimingFunction": {
        "standard": "var(--easing-standard)"
      }
    }
  }
};

export default config;
"
`;
