# Supabase (optional). Without these, Yahoda runs local-first using IndexedDB only.
# Create a project at https://supabase.com, then run supabase/migrations/0001_init.sql
# in the SQL editor. Copy the Project URL and the publishable (anon/public) key below
# into apps/web/.env.local — NOT this file (.env.example is committed to git).
NEXT_PUBLIC_SUPABASE_URL=
# New-style key (sb_publishable_...) from Project Settings → API. The legacy JWT anon key
# is also accepted under NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
